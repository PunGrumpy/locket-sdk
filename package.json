{
  "name": "locket-sdk-monorepo",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vp run -r --parallel dev",
    "build": "vp run -r build",
    "test": "vp run -r test",
    "check": "vp check",
    "fix": "vp check --fix",
    "typecheck": "vp run -r typecheck",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "typescript": "^5.4.0",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "bun": ">=1",
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vite-plus": "latest"
  }
}
